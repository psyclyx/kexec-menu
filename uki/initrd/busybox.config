# Busybox config fragment for kexec-menu initrd.
#
# Applied on top of allnoconfig. Only the applets needed by /init and
# the optional rescue shell are enabled here. The build script
# (scripts/mkbusybox.sh) merges these into the generated .config.

# --- Build options ---
CONFIG_STATIC=y
CONFIG_NO_DEBUG_LIB=y
CONFIG_INSTALL_NO_USR=y
CONFIG_LFS=y
CONFIG_CROSS_COMPILER_PREFIX=""

# --- Applets needed by /init ---
CONFIG_MOUNT=y
CONFIG_UMOUNT=y
CONFIG_MKDIR=y
CONFIG_SLEEP=y
CONFIG_HALT=y
CONFIG_ECHO=y

# --- Rescue shell applets ---
CONFIG_ASH=y
CONFIG_LS=y
CONFIG_CAT=y
CONFIG_CP=y
CONFIG_MV=y
CONFIG_RM=y
CONFIG_LN=y
CONFIG_GREP=y
CONFIG_VI=y
CONFIG_PS=y
CONFIG_KILL=y
CONFIG_DMESG=y
CONFIG_DF=y
CONFIG_DU=y
CONFIG_FIND=y
CONFIG_HEAD=y
CONFIG_TAIL=y
CONFIG_HEXDUMP=y
CONFIG_DD=y
