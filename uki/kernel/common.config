# kexec-menu kernel config fragment — shared options
# Applied on top of tinyconfig for both x86_64 and aarch64.

# EFI stub (the kernel IS the EFI application)
CONFIG_EFI=y
CONFIG_EFI_STUB=y

# kexec support
CONFIG_KEXEC=y
CONFIG_KEXEC_FILE=y

# Block layer
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y

# Storage drivers
CONFIG_ATA=y
CONFIG_SATA_AHCI=y
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV_NVME=y
CONFIG_SCSI=y
CONFIG_SCSI_MOD=y
CONFIG_BLK_DEV_DM=y
CONFIG_USB_STORAGE=y

# Virtio (QEMU testing + cloud)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_SCSI_VIRTIO=y
CONFIG_VIRTIO_INPUT=y

# USB
CONFIG_USB=y
CONFIG_USB_SUPPORT=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_BTRFS_FS=y
CONFIG_BCACHEFS_FS=y
CONFIG_XFS_FS=y
CONFIG_F2FS_FS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# dm-crypt / LUKS
CONFIG_DM_CRYPT=y
CONFIG_CRYPTO=y
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_CRC32C=y
CONFIG_CRYPTO_USER_API_SKCIPHER=y
CONFIG_CRYPTO_USER_API_HASH=y
CONFIG_CRYPTO_USER_API_AEAD=y

# Compression libraries (needed by btrfs, bcachefs, F2FS)
CONFIG_ZLIB_INFLATE=y
CONFIG_ZLIB_DEFLATE=y
CONFIG_LZO_COMPRESS=y
CONFIG_LZO_DECOMPRESS=y
CONFIG_LZ4_DECOMPRESS=y
CONFIG_ZSTD_DECOMPRESS=y
CONFIG_ZSTD_COMPRESS=y

# Checksum algorithms (bcachefs: xxhash, crc64)
CONFIG_XXHASH=y
CONFIG_CRC64=y
CONFIG_CRYPTO_XXHASH=y

# F2FS compression support
CONFIG_F2FS_FS_COMPRESSION=y
CONFIG_F2FS_FS_LZ4=y
CONFIG_F2FS_FS_ZSTD=y

# Console & display
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_HW_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FB=y
CONFIG_FB_SIMPLE=y
CONFIG_DRM=y
CONFIG_DRM_SIMPLEDRM=y

# Framebuffer logo
CONFIG_LOGO=y
CONFIG_LOGO_LINUX_CLUT224=y

# Input
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_INPUT_EVDEV=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y

# Misc required
CONFIG_PRINTK=y
CONFIG_MULTIUSER=y
CONFIG_BINFMT_ELF=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_FILE_LOCKING=y
