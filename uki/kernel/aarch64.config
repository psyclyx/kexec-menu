# kexec-menu kernel config fragment — aarch64 specifics
# Applied on top of tinyconfig + common.config.

CONFIG_64BIT=y
CONFIG_ARM64=y
CONFIG_SMP=y

# ACPI + device tree (UEFI aarch64 platforms use ACPI)
CONFIG_ACPI=y
CONFIG_OF=y

# PCI (ECAM for UEFI platforms)
CONFIG_PCI=y
CONFIG_PCI_MSI=y
CONFIG_PCI_HOST_GENERIC=y

# aarch64 serial console
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# MMC/eMMC/SD (SBCs, phones, tablets)
CONFIG_MMC=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y

# GPIO keys (Android volume keys, SBC buttons)
CONFIG_KEYBOARD_GPIO=y
CONFIG_INPUT_GPIO_KEYS=y

# aarch64 RNG
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_ARM64_CRYPTO=y
CONFIG_CRYPTO_AES_ARM64_CE=y
CONFIG_CRYPTO_SHA2_ARM64_CE=y
