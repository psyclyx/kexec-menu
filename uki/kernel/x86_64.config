# kexec-menu kernel config fragment — x86_64 specifics
# Applied on top of tinyconfig + common.config.

CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y

# ACPI (required for hardware discovery on x86)
CONFIG_ACPI=y
CONFIG_ACPI_BUTTON=y

# PCI
CONFIG_PCI=y
CONFIG_PCI_MSI=y

# x86 EFI
CONFIG_EFI_MIXED=y

# x86 console
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# PS/2 keyboard
CONFIG_SERIO=y
CONFIG_SERIO_I8042=y

# x86 kexec
CONFIG_KEXEC_BZIMAGE_VERIFY_SIG=n

# x86 RNG (needed for bcachefs/crypto)
CONFIG_ARCH_RANDOM=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_INTEL=y
CONFIG_HW_RANDOM_AMD=y
